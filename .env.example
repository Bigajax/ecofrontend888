# Base URL used for Supabase auth redirect callbacks.
# Uncomment the appropriate value for your environment before running the app.
VITE_APP_URL=https://your-production-domain.com
# VITE_APP_URL=http://localhost:5173

# Supabase project settings
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional integrations
VITE_API_URL=https://ecobackend888.onrender.com
# Kill-switch do "paywall focado" (/sono/experiencia). Ausente/qualquer valor = ON
# (rollout). Defina como 'false' para rollback sem deploy de código.
# VITE_PAYWALL_FOCO=false
# Kill-switch da "entrada sem modal" (/sono/experiencia): "Ouvir a Noite 1" vai
# direto ao player. Ausente/qualquer valor = ON. 'false' religa o modal de entrada.
# VITE_ENTRADA_SEM_MODAL=false
# Kill-switch do bônus EcoDream na oferta do sono. Ausente/qualquer valor = ON.
# 'false' esconde o bônus e volta o CTA original.
# VITE_OFERTA_BONUS=false
VITE_ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Meta (Facebook) Pixel
# OBS: o Pixel ID do browser é carregado direto no index.html (snippet base),
# não por env var. VITE_FB_PIXEL_ID está mantido só por compatibilidade.
VITE_FB_PIXEL_ID=your-facebook-pixel-id
# Conversions API (CAPI) — usado pela função serverless /api/meta/event para
# deduplicar eventos browser+servidor. Configure no painel da Vercel (NÃO são
# VITE_*, ficam só no servidor). Sem eles, o CAPI responde 500 e o Pixel do
# browser continua funcionando sozinho.
# DEVE ser o MESMO ID do fbq('init') no index.html (1452404496069451), senão o
# CAPI manda pra outro pixel e a deduplicação browser+servidor quebra.
META_PIXEL_ID=1452404496069451
META_ACCESS_TOKEN=your-meta-capi-access-token
# Opcional: código de teste do Events Manager para validar eventos no painel.
META_TEST_EVENT_CODE=
# IMPORTANTE: o backend (ecobackend888) também dispara CAPI no webhook do Mercado
# Pago (StartTrial/Subscribe). Use o MESMO META_PIXEL_ID lá para a deduplicação
# por event_id funcionar. Ver META_CAPI_TOKEN no .env do backend.

# Mercado Pago - Subscription System
# Get your public key from https://www.mercadopago.com.br/developers/panel/app
VITE_MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google OAuth Client ID for One Tap Sign-In
# Get this from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Vercel Blob Storage - Videos
# Note: These are public URLs. NEVER use ECOTOPIA_VIDEOS_READ_WRITE_TOKEN in frontend code.
VITE_VIDEO_CALEIDOSCOPIO_DINHEIRO=https://e6qcazsomcrmqybj.public.blob.vercel-storage.com/Caleidoscopio%20manifesta%C3%A7%C3%A3o%20do%20dinheiro.mp4
VITE_VIDEO_CALEIDOSCOPIO_SAUDE=https://e6qcazsomcrmqybj.public.blob.vercel-storage.com/Manifesta%C3%A7%C3%A3o%20da%20sa%C3%BAde.mp4
